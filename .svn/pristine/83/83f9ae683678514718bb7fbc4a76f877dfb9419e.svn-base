<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Document</title>
    <script type="text/javascript">
    /*
    条件分支语句，也叫switch语句
    语法：
    switch(条件表达式){
        case 表达式：
             语句
             break;
        case 表达式：
             语句
             break;
        case 表达式：
             语句
             break;
        default:
            语句
            break;
    }

    执行流程：
         switch...case...语句

         在执行时会一次将switch后的表达式和case后的表达式的值进行“==”比较
         如结果为true，则从当前case处开始执行代码，
         （注：当前case后的所有代码都会被执行，因此必须加break
               这样可以确保只会执行当前case后的语句，而不会执行其他的case）
         如结果为false，则继续向下比较，
         如都为false，则执行default后的语句
    Switch和if功能有重复，可以互换，但一般if更常用
    */

    //根据num值，输出对应的中文
    //方法一：if语句
    var num="hello";
    if(num==1){
        console.log("壹");
    }else if(num==2){
        console.log("贰");
    }else if(num==3){
        console.log("叁");
    }else{
        console.log("非法数字");
    }//壹
    //方法二：switch语句
    var num="abc";
    switch(num){
        case 1:
            console.log("壹");
            break;//使用break退出switch语句
        case 2:
            console.log("贰");
            break;
        case 3:
            console.log("叁");
            break;
        default:
            console.log("非法数字")
    }//贰

    
    
    </script>
</head>
<body>
    
</body>
</html>