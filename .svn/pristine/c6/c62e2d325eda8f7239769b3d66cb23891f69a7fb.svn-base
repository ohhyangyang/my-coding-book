<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Document</title>
    <script type="text/javascript">
    /*
    遍历数组：把数组中的所有元素都取出来
    */
    var arr=["a","b","c","d"];

    for(i=0;i<arr.length;i++){
        console.log(arr[i]);
    }//a  b  c  d  

    for(var n in arr){
        console.log(arr[n]);
    }


    </script>
</head>
<body>
    
</body>
</html>