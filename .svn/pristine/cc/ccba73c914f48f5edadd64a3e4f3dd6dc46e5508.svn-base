<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Document</title>
    <style type="text/css">
        img {
            width: 500px;
        }
    </style>
    <script type="text/javascript">
        window.onload = function () {
            //使图片可以自动切换
            var img = document.getElementById("img");
            //创建一个数组来保存图片路径
            var imgArr = ["img/1.jpg", "img/2.jpg", "img/3.jpg", "img/4.jpg", "img/5.jpg"];
            //创建图片的索引，显示第一张
            var index = 0;
            var btn01 = document.getElementById("btn01");
            var btn02 = document.getElementById("btn02");
            var timer;//变量设在外面
            btn01.onclick = function () {
                clearInterval(timer);//⚠️⚠️
                /*
                在开启一个定时器之前，必须要关闭当前元素上的其他定时器
                （即使之前没有设置定时器，clearInterval()也不会报错)
                否则，每点击一次start就会开启一个定时器
                 点击多次就会开启多个定时器，会导致整个图片切换错乱
                 并且只可以使用stop关闭最后一次开启的定时器
                */
                timer = setInterval(function () {
                    index++;
                    if (index >= imgArr.length) {
                        index = 0;
                    }//简写：index%=imgArr.length;
                    img.src = imgArr[index];
                }, 1000)
            };
            btn02.onclick = function () {
                clearInterval(timer);
                /*
                clearInterval()可以接受任意参数
                如果参数是一个有效的定时器标识，则停止对应的定时器
                如果参数不是一个有效的标识，则什么也不做
                */
            };
        };

    </script>
</head>

<body>
    <img id="img" src="img/1.jpg" />
    <br />
    <button id="btn01">START</button>
    <button id="btn02">STOP</button>
</body>

</html>