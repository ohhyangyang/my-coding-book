<!doctype html>
<html>
    <head>
        <meta charset="UTF-8"/>
        <title>导航条</title>
        <style type="text/css">
        *{
            margin: 0;
            padding: 0;
        }
        .nav{
            list-style: none;
            background-color:tan;
            overflow: hidden;
            width:1200px;
            margin: 10px auto;
        }
        .nav li{
            float: left;
            width:12.5%;
        }
        .nav a{
            text-decoration: none;
            color: white;
            font: 15px "Arial";
            display:block;
            width: 100%;
            padding:2px 0;
            text-align: center;
            
        }
        .nav a:hover{
            background-color: yellow;
        }
        </style>
    </head>
    <body>
        <ul class="nav">
            <li><a href="#">YANGGE</a></li>
            <li><a href="#">PROJECTS</a></li>
            <li><a href="#">PROFILE</a></li>
            <li><a href="#">NEWS</a></li>
            <li><a href="#">LIFE</a></li>
            <li><a href="#">FRIENDS</a></li>
            <li><a href="#">CONTACT</a></li>
            <li><a href="#">SEARCH</a></li>
            
        </ul>
    </body>
</html>