<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8"/>
        <title>浮动</title>
        <style type="text/css">
        /*
        
        */
        *{
            margin: 0;
            padding:0;
        }
        .header{
            width:1000px;
            height: 150px;
            background-color: sandybrown;
            margin:0 auto;/*设置居中*/
        }
        .content{
            width:1000px;
            height:500px;
            background-color:white;
            margin: 10px auto;
        }
        .footer{
            width:1000px;
            height:150px;
            background-color:skyblue;
            margin:0 auto;
        }
        .left{
            width:190px;
            height:100%;
            background-color: pink;
            float:left;
        }
        .center{
            width:60%;
            height:100%;
            background-color:whitesmoke;
            float:left;
            margin:0 10px;
        }
        .right{
            width:190px;
            height:100%;
            background-color: pink;
            float:left;
        }
        
        </style>
    </head>
    <body>
        <div class="header"></div>
        <div class="content">
            <div class="left"></div>
            <div class="center"></div>
            <div class="right"></div>
        </div>
        <div class="footer"></div>
        
        
    </body>
</html>