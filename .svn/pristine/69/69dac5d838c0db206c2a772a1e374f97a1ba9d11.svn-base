<!doctype html>
<html>
    <head>
        <meta charset="UTF-8"/>
        <title>固定定位</title>
        <style type="text/css">
        /*
        固定定位 position:fixed;
        固定定位也是一种绝对定位，但是:
        固定定位永远都会相对于浏览器窗口进行定位
        元素会固定在浏览器的某个位置，不会随滚动条移动
        ⚠️IE6不支持固定定位
        */
        .box1{
            width: 200px;
            height: 200px;
            background-color: red;
        }
        .box2{
            width: 200px;
            height: 200px;
            background-color: yellow;
            position: fixed;
            
        }
        .box3{
            width: 300px;
            height: 300px;
            background-color: green;
        }
        body{
            height: 5000px;
        }
        </style>
    </head>
    <body>
        <div class="box1"></div>
        <div class="box2"></div>
        <div class="box3"></div>
    </body>
</html>