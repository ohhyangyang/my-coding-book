<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Document</title>
    <script type="text/javascript">
    /*
    在调用函数时，浏览器每次都会传递进两个隐含参数
       1 函数的拥有者对象（上下文对象）：this
       2 封装实参的对象：arguments
    
    arguments是一个类数组对象（并非是数组对象类型）
    在调用函数时，我们所传递的实参都会在arguments中保存

    获取长度
    arguments.length可以用来获取实参的长度

    操作数据
    arguments[0]表示第一个实参
    arguments[1]表示第二个实参
    （我们即使不定义形参，也可以通过arguments来使用实参）

    callee属性
    arguments.callee对应当前正在指向的函数的对象


    */
    function fun1(){
        console.log(arguments instanceof Array);//false，检查argument对象是否为Array对象的实例
        console.log(Array.isArray(arguments));//false，判断arguments对象是否为数组
        console.log(arguments.length);//2，定义的实参的数量
        console.log(arguments[0]);//hello
        

    }
    fun1("hello",true);
    //注：isArray()方法用于判断一个对象是否为数组。

    function fun2(a,b){
        console.log(arguments.length);//3
        console.log(arguments[1]);//true
        console.log(arguments.callee);/*
                                       function fun2(a,b){
                                       console.log(arguments.length);//3
                                       console.log(arguments[0]);//hello
                                       console.log(arguments.callee);
                                       }   召唤出正在指向的函数对象
                                     */
    }
    fun2("hello",true,1);
    
    
    
    </script>
</head>
<body>
    
</body>
</html>