<!doctype html>
<html>
    <head>
        <meta charset="UTF-8"/>
        <title>常用选择器</title>
        <style type="text/css">
        /*
        并集选择器：

        element元素选择器：通过标签选择页面中所有指定元素
        语法：标签名{}
        */

        p{
            color:red;
        }
        h1{
            color:dodgerblue;
        }

        /*
        id选择器：通过唯一id属性值选中唯一的一个元素
        语法： #id属性值{}
        */
        #p{
            color:green;
            font-size: 20px;
        }

        /*
        class类选择器：通过元素class属性值选择一组元素（class会用的更多）
        语法： .class属性{}

        ⚠️class属性和id属性类似，只不过class属性可以重复
        且可为同一个元素设置多个class属性值，多个值之间用空格隔开
        */
        .class{
            color: blueviolet;
        }
        .hello{
            font-size: 30px;
        }

        /*
        选择器分组：同时选中多个选择器对应的元素
        语法： 选择器1,选择器2,...选择器n{}
        */
        h1,#p,.hello{
            background-color:rgb(0, 0, 0);
        }

        /*
        通配选择器：可以选中页面中所有元素
        语法：*{}
        */
        *{
            background-color: azure;
        }

        /*
        复合选择器（交集选择器）：可选中同时满足多个选择器的元素
        语法：选择器1选择器2...选择器n{}
        ⚠️对于id选择器来说，不建议使用复合选择器
        */
        span.class{
            color:cornflowerblue;
            font-size:30px;
        }


        
        </style>
    </head>
    <body>
        <h1>ABCD</h1>
        <p>ABCD</p>
        <p id="p">ABCD</p>
        <p>ABCD</p>
        <p>ABCD</p>
        <p>ABCD</p>
        <p>ABCD</p>

        <p class="class hello">ABCD</p>
        <p class="class">ABCD</p>
        <p class="class">ABCD</p>

        <p>ABCD</p>
        <p>ABCD</p>
        <p>ABCD</p>
        <p>ABCD</p>
        <p>ABCD</p>
        <p>ABCD</p>
        <span class="class">ABCD</span>
    </body>
</html>