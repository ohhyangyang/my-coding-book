<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Document</title>
    <script type="text/javascript">
    /*
    练习一：
    对于成绩大于60分的，输出“合格”，低于60分的，输出“不合格”
    */
    //方法一
    var score=60;
    switch(parseInt(score/10)){//除以10，再用parseInt取整
        case score=10:
        case score=9:
        case score=8:
        case score=7:
        case score=6:
             console.log("合格");
             break;
        default:
            console.log("不合格");
            break;
    }//合格

    //方法二
    var result=20
    switch(true){
        case result>=60:
        console.log("合格");
             break;
        default:
            console.log("不合格");
            break;
    }//不合格
    
    
    </script>
</head>
<body>
    
</body>
</html>