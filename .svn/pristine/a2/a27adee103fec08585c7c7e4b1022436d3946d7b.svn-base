<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Document</title>
    <script type="text/javascript">
    
    var obj={
        name:"Yang",
        age:18,
        gender:"woman",
        sayName:function(){
            console.log(this.name);
        }
    }
    /*
    使用工厂方法创建对象
    通过该方法可以大批量创建对象
    */
    function createPerson(name,age,gender){
        var obj=new Object();
        obj.name=name;
        obj.age=age;
        obj.gender=gender;
        obj.sayName=function(){
            console.log(this.name);
        };
        return obj;
    }
    var person1=createPerson("Yang",18,"woman");
    var person2=createPerson("Albert",18,"man");
    var person3=createPerson("Mom",18,"woman");
    console.log(person1);//object {name: "Yang", age: 18, gender: "woman", sayName: ƒ}
    console.log(person2);//object {name: "Albert", age: 18, gender: "man", sayName: ƒ}
    console.log(person3);//object {name: "Mom", age: 18, gender: "woman", sayName: ƒ}
    person1.sayName();//Yang
    person2.sayName();//Albert
    person3.sayName();//Mom

    /*
    举例
    创建一个狗的函数
    */
    function createDog(name,age){
        var obj=new Object();
        obj.name=name;
        obj.age=age;
        obj.sayHello=function(){
            alert("汪汪🐶");
        };
        return obj;
    }
    var dog1=createDog("旺财",3);
    dog1.sayHello();//alert:汪汪🐶
    console.log(dog1);//object {name: "旺财", age: 3, sayHello: ƒ}
    
    </script>
</head>
<body>
    
</body>
</html>